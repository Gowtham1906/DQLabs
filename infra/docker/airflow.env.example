# =============================================================================
# DQLabs Airflow — Environment Configuration Template
# =============================================================================
# USAGE:
#   cp infra/docker/airflow.env.example infra/docker/.env
#   # Then edit .env with your real values before running docker compose
#
# IMPORTANT:
#   - .env is for LOCAL DEVELOPMENT only.
#   - Never commit a populated .env to version control (.gitignore must cover it).
#   - For production, inject all secrets via K8s Secrets or a vault provider.
#
# Key generation commands:
#   Fernet key : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Secret key : python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================


# -----------------------------------------------------------------------------
# Image build configuration
# -----------------------------------------------------------------------------
AIRFLOW_VERSION=2.8.1
PYTHON_VERSION=3.11

# Image tag — use semantic versioning (MAJOR.MINOR.PATCH)
IMAGE_TAG=3.0.0

# Airflow process user UID/GID (50000 is the community standard)
AIRFLOW_UID=50000
AIRFLOW_GID=50000

# Set to "true" to include OpenJDK 17 in the image.
# Required for: Hive JDBC, Spark JDBC, Apache Iceberg connectors
# Effect: adds ~280 MB to the final image
INSTALL_JAVA=false


# -----------------------------------------------------------------------------
# PostgreSQL — Airflow metadata database
# -----------------------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=airflow
POSTGRES_HOST=airflow-db
POSTGRES_PORT=5432

# Host port mapping for direct DB access during local development
POSTGRES_PORT_EXTERNAL=5437


# -----------------------------------------------------------------------------
# Redis — Celery message broker
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379


# -----------------------------------------------------------------------------
# Airflow core
# -----------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=CeleryExecutor

# REQUIRED: Generate with the Fernet command shown at the top of this file.
# This key encrypts sensitive connection passwords in the Airflow metadata DB.
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_generate_with_fernet_key_gen

AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16


# -----------------------------------------------------------------------------
# Airflow webserver
# -----------------------------------------------------------------------------
AIRFLOW_WEBSERVER_PORT=8080

# REQUIRED: Generate with the secrets command shown at the top of this file.
AIRFLOW__WEBSERVER__SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex


# -----------------------------------------------------------------------------
# Airflow Celery worker
# -----------------------------------------------------------------------------
# Number of concurrent tasks per worker process
AIRFLOW__CELERY__WORKER_CONCURRENCY=4


# -----------------------------------------------------------------------------
# Airflow logging
# -----------------------------------------------------------------------------
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO


# -----------------------------------------------------------------------------
# Airflow admin user (created on first init)
# -----------------------------------------------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_admin_password
AIRFLOW_ADMIN_EMAIL=admin@dqlabs.io


# -----------------------------------------------------------------------------
# Flower — Celery monitoring UI
# -----------------------------------------------------------------------------
FLOWER_PORT=5555


# -----------------------------------------------------------------------------
# AWS credentials
# LOCAL DEV ONLY — use IRSA or instance profiles in production (never hardcode)
# Leave blank if not using AWS connectors during local development.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1


# -----------------------------------------------------------------------------
# Azure (leave blank if not using Azure connectors locally)
# -----------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=


# -----------------------------------------------------------------------------
# DQLabs application configuration
# These values are read by the dqlabs package at runtime.
# -----------------------------------------------------------------------------
CLIENT_NAME=dqlabs

# Application database connection (may differ from Airflow metadata DB)
POSTGRESQL_DB_NAME=airflow
POSTGRESQL_USER_NAME=airflow
POSTGRESQL_PASSWORD=CHANGE_ME_strong_password
POSTGRESQL_HOST=airflow-db
POSTGRESQL_PORT=5432

# Application secret key (used by crypto_helper.py for encrypting connector creds)
SECRET_KEY=CHANGE_ME_application_secret_key