# =============================================================================
# DQLabs Airflow – Environment Variables Template
#
# Copy and rename before use:
#   cp infra/docker/env.example infra/docker/.env
#
# NEVER commit .env to source control.
# =============================================================================

# ── Airflow Fernet Key ────────────────────────────────────────────────────────
# Generate once:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# ── Airflow Webserver Secret ──────────────────────────────────────────────────
# Any long random string — used to sign session cookies
AIRFLOW__WEBSERVER__SECRET_KEY=

# ── Airflow metadata DB password ─────────────────────────────────────────────
# Password for the internal 'airflow' Postgres user (local container only)
AIRFLOW_POSTGRES_PASSWORD=airflow_local_pass

# ── Airflow Admin User (created on first boot) ────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_EMAIL=admin@dqlabs.io
AIRFLOW_ADMIN_PASSWORD=admin

# ── DQLabs Business Database (your data quality DB) ──────────────────────────
# Different from the Airflow metadata DB above
POSTGRESQL_DB_NAME=
POSTGRESQL_USER_NAME=
POSTGRESQL_PASSWORD=
POSTGRESQL_HOST=
POSTGRESQL_PORT=5432

# ── DQLabs Application ────────────────────────────────────────────────────────
CLIENT_NAME=dqlabs
SECRET_KEY=
DEBUG=false
LOG_BACKUP_COUNT=10

# ── DQLabs Airflow Plugin Variables ──────────────────────────────────────────
# These are seeded into Airflow Variables via dq_variables.json on first boot.
# You can also set them manually in Admin → Variables in the Airflow UI.
# DQ_ENDPOINT_URL=
# DQ_CLIENT_ID=
# DQ_CLIENT_SECRET=
# DQ_CONNECTION_NAME=
# DQ_ALLOWED_DAGS=
# DQ_EXCLUDED_DAGS=
# DQ_EXTRACT_SOURCE_CODE=false

# ── AWS (if using S3 / Athena / Redshift / EMR) ───────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── Azure (if using Synapse / ADLS / ADF) ────────────────────────────────────
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# ── Notifications ─────────────────────────────────────────────────────────────
# SLACK_API_TOKEN=
# SENDGRID_API_KEY=
